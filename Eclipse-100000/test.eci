~Init:
    LMA rx0 <- 0
    LMA rx1 <- 1
    LOAD rx2 <- 0
    LMA rx3 <- 100000
    LMA rx4 <- 1024
    LMA rx5 <- 4

~Loop:
    CMP rx0, rx3
    BGU ~End

    STR [rx0, rx4]
    ADD [rx4, rx5]

    ADD [rx2, rx1]

    ADD [rx1, rx0]

    XOR [rx0, rx0]
    ADD [rx0, rx2]

    XOR [rx2, rx2]

    JMP ~Loop

~End:

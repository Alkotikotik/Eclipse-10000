~Init:
    LMA rx0 <- 0
    LMA rx1 <- 1
    LOAD rx2 <- 0
    LMA rx3 <- 100000

    LMA r4 <- 4088
    LOAD rz50 <- 2
    LOAD ry51 <- 2

    CALL ~A

~Loop:
    CMP rx0, rx3
    BGU ~End

    STR [rx0, rx4]
    SUB [rx4, rz50]
    SUB [rx4, ry51]

    ADD [rx2, rx1]

    ADD [rx1, rx0]

    XOR [rx0, rx0]
    ADD [rx0, rx2]

    XOR [rx2, rx2]

    JMP ~Loop

~A:
    STR [rx3, rx4 + 4]
    RET

~End:
    LOAD rx0 <- 0
    JR rx0

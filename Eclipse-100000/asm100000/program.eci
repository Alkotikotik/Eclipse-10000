~Init:
>_Fibbonachi
    LOAD rx12 <- 0
    LOAD rx1 <- 1

    LOAD rx3 <- 1000
    LOAD rx4 <- 1000

    MUL [rx3, rx4]
    LOAD rx5 <- 4092
    LOAD rx6 <- 4
    LOAD rx2 <- 0

~Loop:
    STR rx12, rx5
    SUB [rx5, rx6]

    ADD [rx2, rx12]

    ADD [rx12, rx1]

    >_Due to the lack of mov command I just do this instead
    XOR [rx1, rx1]
    ADD [rx1, rx2]

    XOR [rx2, rx2]

    BS rx12, rx3, ~Loop

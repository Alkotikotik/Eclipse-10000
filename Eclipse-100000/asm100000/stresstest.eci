~Init:
    LOAD rx1 <- 4096
    LOAD rx2 <- 0
    LOAD rx3 <- 4
    LOAD rx4 <- 40

~WriteLoop:
    >_ Hammer RAM forward
    STR rx2, [rx1 + 0]
    ADD [rx1, rx3]
    ADD [rx2, rx3]
    BS rx2, rx4, ~WriteLoop

~ReadLoop:
    LDR rx5, [rx1 - 4]
    SUB [rx2, rx3]
    SUB [rx1, rx3]
    
    BNE rx5, rx2, ~Trap
    
    LOAD rx6 <- 0
    BG rx2, rx6, ~ReadLoo

~Success:
    XOR [rx31, rx31]
    LOAD rx31 <- 42
    JMP ~Success

~Trap:
    XOR [rx31, rx31]
    LOAD rx31 <- 255
    JMP ~Trap

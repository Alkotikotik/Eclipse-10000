~Init:
>_Fibbonachi
    LOAD rx0 <- 0
    LOAD rx1 <- 1

    LOAD rx3 <- 31
    LOAD rx4 <- 31

    MUL [rx3, rx4]
    LOAD rx5 <- 0
    LOAD rx6 <- 1
    LOAD rx2 <- 0
~Loop:
    STR rx0, rx5
    ADD [rx5, rx6]

    ADD [rx2, rx0]

    ADD [rx0, rx1]
    
    >_Due to the lack of mov command I just do this instead
    XOR [rx1, rx1]
    ADD [rx1, rx2]

    XOR [rx2, rx2]

    BS rx0, rx3, ~Loop

